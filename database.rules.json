{
  "rules": {
    "draftedPlayers": {
      ".read":  "auth != null",
      ".write": "auth != null && auth.token.email == 'admin@busterleague.local'"
    },
    "draftState": {
      ".read":  "auth != null && auth.token.email == 'admin@busterleague.local'",
      ".write": "auth != null && auth.token.email == 'admin@busterleague.local'"
    },
    "watchlists": {
      "$team": {
        ".read":  "auth != null && auth.token.email == ($team + '@busterleague.local')",
        ".write": "auth != null && auth.token.email == ($team + '@busterleague.local')"
      }
    },
    "rankings": {
      "$team": {
        ".read":  "auth != null && auth.token.email == ($team + '@busterleague.local')",
        ".write": "auth != null && auth.token.email == ($team + '@busterleague.local')"
      }
    },
    "dnw": {
      "$team": {
        ".read":  "auth != null && auth.token.email == ($team + '@busterleague.local')",
        ".write": "auth != null && auth.token.email == ($team + '@busterleague.local')"
      }
    },
    "colprefs": {
      "$team": {
        ".read":  "auth != null && auth.token.email == ($team + '@busterleague.local')",
        ".write": "auth != null && auth.token.email == ($team + '@busterleague.local')"
      }
    }
  }
}
